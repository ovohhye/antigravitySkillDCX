const tierLabel = { essential: '필수', recommended: '권장', optional: '선택', gap: '스킬 없음' };
const tierCls = { essential: 'tag-essential', recommended: 'tag-recommended', optional: 'tag-optional', gap: 'tag-gap' };

let currentPhase = 'd1';
let currentTask = null;

function renderSidebar(phase) {
  const d = data[phase];
  const sidebar = document.getElementById('sidebar');
  const activeCls = `active-${phase}`;
  sidebar.innerHTML = `<div class="sidebar-label">UX Tasks</div>` +
    d.tasks.map((t, i) => `
      <div class="task-item ${currentTask === t.id ? 'active ' + activeCls : ''}"
           id="si-${t.id}" onclick="scrollToTask('${t.id}')">
        <span class="task-num">T${String(i+1).padStart(2,'0')}</span>
        <span class="task-name">${t.name}</span>
      </div>
    `).join('');
}

function countSkills(phase) {
  const d = data[phase];
  let essential = 0, recommended = 0, optional = 0;
  d.tasks.forEach(t => t.skills.forEach(s => {
    if (s.tier === 'essential') essential++;
    else if (s.tier === 'recommended') recommended++;
    else if (s.tier === 'optional') optional++;
  }));
  return { essential, recommended, optional };
}

function renderContent(phase) {
  const d = data[phase];
  const counts = countSkills(phase);
  const content = document.getElementById('content');

  content.innerHTML = `
    <div class="phase-header">
      <span class="phase-badge bg-${phase}">${d.phase}</span>
      <span class="phase-title c-${phase}">${d.phase}</span>
    </div>
    <div class="phase-desc">${d.desc}</div>

    ${d.tasks.map((t, i) => `
      <div class="task-section" id="${t.id}">
        <div class="task-section-header">
          <span class="task-section-num c-${phase}">T${String(i+1).padStart(2,'0')}</span>
          <span class="task-section-title">${t.name}</span>
          <span class="task-section-why">${t.why}</span>
        </div>
        <div class="skill-cards">
          ${t.skills.map(s => `
            <div class="skill-card ${s.tier === 'essential' ? 'essential border-' + phase : ''}">
              <div class="sc-top">
                <span class="sc-name">${s.name}</span>
                <span class="sc-tag ${tierCls[s.tier]}">${tierLabel[s.tier]}</span>
              </div>
              <div class="sc-desc">${s.desc}</div>
              <div class="sc-use">활용: ${s.use}</div>
            </div>
          `).join('')}
          ${t.hasGap ? `
            <div class="no-skill">
              <div class="no-skill-title">⚠ 이 task를 전담하는 스킬 없음</div>
              <div class="no-skill-desc">${t.gapDesc}</div>
            </div>
          ` : ''}
        </div>
      </div>
    `).join('')}

    <div class="phase-summary">
      <div class="summary-item">
        <div class="summary-num c-${phase}">${counts.essential}</div>
        <div class="summary-label">필수 스킬</div>
      </div>
      <div class="summary-item">
        <div class="summary-num" style="color:var(--d2)">${counts.recommended}</div>
        <div class="summary-label">권장 스킬</div>
      </div>
      <div class="summary-item">
        <div class="summary-num" style="color:var(--text3)">${counts.optional}</div>
        <div class="summary-label">선택 스킬</div>
      </div>
      <div class="summary-item" style="margin-left:auto">
        <div class="summary-num" style="color:var(--text2)">${counts.essential + counts.recommended + counts.optional}</div>
        <div class="summary-label">총 스킬</div>
      </div>
    </div>
  `;
}

function switchPhase(phase) {
  currentPhase = phase;
  currentTask = data[phase].tasks[0].id;

  // nav active state
  ['d1','d2','d3','d4'].forEach(p => {
    const nav = document.getElementById('nav-' + p);
    nav.className = 'dnav-item';
    if (p === phase) nav.classList.add('active-' + p);
  });

  renderSidebar(phase);
  renderContent(phase);
}

function scrollToTask(taskId) {
  currentTask = taskId;
  const el = document.getElementById(taskId);
  if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });

  // update sidebar active
  document.querySelectorAll('.task-item').forEach(item => {
    item.classList.remove('active', 'active-d1', 'active-d2', 'active-d3', 'active-d4');
  });
  const si = document.getElementById('si-' + taskId);
  if (si) {
    si.classList.add('active', 'active-' + currentPhase);
  }
}

// init
switchPhase('d1');
</script>
</body>
</html>
